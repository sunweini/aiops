#!/usr/bin/env python3
"""host-query CLI — 主机实时状态查询（系统全局安装）。"""

import sys
import os

# 添加 host-access 目录到 Python 路径
HOST_ACCESS_DIR = "/root/.openclaw/workspace-shared/aiops/host-access"
sys.path.insert(0, HOST_ACCESS_DIR)
os.chdir(HOST_ACCESS_DIR)

from cli.host_query import cmd_status, cmd_items

if __name__ == "__main__":
    if len(sys.argv) < 3:
        print(__doc__)
        sys.exit(1)

    cmd = sys.argv[1]
    arg = sys.argv[2]

    if cmd == "status":
        cmd_status(arg)
    elif cmd == "items":
        cmd_items(arg)
    else:
        print(f"Unknown command: {cmd}")
        sys.exit(1)
