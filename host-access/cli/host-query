#!/usr/bin/env python3
"""Executable wrapper for host-query CLI."""
import os, sys

# Ensure the cli package directory is on the path so the module is importable
sys.path.insert(0, os.path.dirname(os.path.dirname(os.path.abspath(__file__))))

from cli.host_query import cmd_status, cmd_items

if __name__ == "__main__":
    if len(sys.argv) < 3:
        print(__doc__)
        sys.exit(1)

    cmd = sys.argv[1]
    arg = sys.argv[2]

    if cmd == "status":
        cmd_status(arg)
    elif cmd == "items":
        cmd_items(arg)
    else:
        print(f"Unknown command: {cmd}")
        sys.exit(1)
